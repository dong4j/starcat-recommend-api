# ================================
# starcat-recommend-api .env.example
# ================================
# 复制此文件为 .env 并填实际值。
# .env 不会提交到 git（已在 .gitignore）。
# fly.io 部署时用 `fly secrets set` 而非 .env。

# ──────────────── 服务端口 ────────────────
PORT=5005

# ──────────────── API 鉴权白名单（必填）────────────────
# 逗号分隔多个 key；与 Starcat 客户端服务设置中的 Recommend API Key 对应。
API_KEYS=sk-starcat-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────── SimRepo 上游（必填）────────────────
# 只放在后端, 不得写入 Starcat macOS 客户端。
SIMREPO_API_KEY=replace-with-simrepo-readonly-key
SIMREPO_ENDPOINT=https://simrepo.dera.page/collections/repos/points/recommend

# ──────────────── 进程内缓存 TTL（秒）────────────────
CACHE_TTL_SUCCESS_SECONDS=604800
CACHE_TTL_EMPTY_SECONDS=3600
CACHE_TTL_ERROR_SECONDS=600
